+import Foundation
+import UserNotifications
+
+// manages all push notifications for the app
+class notificationsManager {
+
+    static var Instance = notificationsManager()
+
+    var Granted = false
+    var badge_count = 0
+    var pendingNotifications = [UNNotificationRequest]()
+
+    func RequestPermission(completion: @escaping (Bool) -> Void) {
+        UNUserNotificationCenter.current().requestAuthorization(options: [.alert, .badge, .sound]) {
+            granted, error in
+            self.Granted = granted
+            completion(granted)
+        }
+    }
+
+    func ScheduleNotification(Title: String, Body: String, Date: Date) {
+        let content = UNMutableNotificationContent()
+        content.title = Title
+        content.body = Body
+        content.badge = NSNumber(value: self.badge_count + 1)
+
+        let components = Calendar.current.dateComponents([.year,.month,.day,.hour,.minute], from: Date)
+        let trigger = UNCalendarNotificationTrigger(dateMatching: components, repeats: false)
+
+        let id = NSUUID().uuidString
+        let req = UNNotificationRequest(identifier: id, content: content, trigger: trigger)
+
+        UNUserNotificationCenter.current().add(req) { error in
+            if error != nil {
+                print("error scheduling notification: \(error!)")
+            } else {
+                self.pendingNotifications.append(req)
+                self.badge_count += 1
+            }
+        }
+    }
+
+    func CancelAll() {
+        UNUserNotificationCenter.current().removeAllPendingNotificationRequests()
+        pendingNotifications.removeAll()
+        badge_count = 0
+    }
+
+    func GetPending(completion: @escaping ([UNNotificationRequest]) -> Void) {
+        UNUserNotificationCenter.current().getPendingNotificationRequests { requests in
+            completion(requests)
+        }
+    }
+
+    func update_badge(count: Int) {
+        badge_count = count
+        DispatchQueue.main.async {
+            UIApplication.shared.applicationIconBadgeNumber = count
+        }
+    }
+}
