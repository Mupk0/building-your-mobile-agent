@@ -0,0 +1,35 @@
+import UIKit
+
+class feed_cell: UITableViewCell {
+
+    @IBOutlet var TitleLabel : UILabel!
+    @IBOutlet var SubtitleLabel : UILabel!
+    @IBOutlet var ThumbImage : UIImageView!
+    @IBOutlet var TimeStampLabel: UILabel!
+
+    var DATA: [String: Any]?
+
+    override func awakeFromNib() {
+        super.awakeFromNib()
+    }
+
+    func Configure(data: [String: Any]) {
+        DATA = data
+        TitleLabel.text    = data["title"] as? String
+        SubtitleLabel.text = data["subtitle"] as? String
+        TimeStampLabel.text = data["ts"] as? String
+
+        if let url = data["thumb"] as? String {
+            LoadImage(urlString: url)
+        }
+    }
+
+    func LoadImage(urlString: String) {
+        guard let url = URL(string: urlString) else { return }
+        URLSession.shared.dataTask(with: url) { data, _, _ in
+            if let data = data, let img = UIImage(data: data) {
+                DispatchQueue.main.async {
+                    self.ThumbImage.image = img
+                }
+            }
+        }.resume()
+    }
+}
